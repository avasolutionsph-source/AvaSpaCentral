---
import Layout from '../layouts/Layout.astro';
import SectionDecor from '../components/SectionDecor.astro';
import FaqItem from '../components/FaqItem.astro';
---

<Layout title="Contact — AVA Spa Central" description="Contact AVA Spa Central — schedule a demo, ask pricing questions, or visit our office in Makati. Response within one business day." active="contact">

  <!-- HERO -->
  <section class="py-[100px] pb-[80px] text-center relative overflow-hidden bg-ivory" style="background: radial-gradient(circle at 15% 25%, rgba(0,92,69,.05) 0%, transparent 40%), radial-gradient(circle at 85% 75%, rgba(201,154,58,.06) 0%, transparent 42%), var(--color-ivory);">
    <span class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-14" style="background:linear-gradient(180deg, transparent 0%, var(--color-gold-brand) 100%); opacity:.6;"></span>
    <div class="container-spa relative z-[2]">
      <div class="max-w-[760px] mx-auto">
        <span class="eyebrow inline-block mb-[18px]">Let's Talk</span>
        <h1 class="mb-5 tracking-tight">Questions? <span class="block italic text-emerald-brand font-medium">We'd love to hear from you.</span></h1>
        <p class="text-[1.1rem] max-w-[560px] mx-auto leading-relaxed">Send us a message, schedule a demo, or stop by the office. We respond within one business day — usually much sooner.</p>
      </div>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <section class="py-[80px] pb-[110px] bg-ivory relative overflow-hidden">
    <SectionDecor orbs={["gold-tl","em-br"]} image="/5-nobg.png" imagePos="br" />
    <div class="container-spa relative z-[2]">
      <div class="grid grid-cols-1 md:grid-cols-[1.4fr_1fr] gap-12 max-w-[1180px] mx-auto reveal">
        <div class="bg-white border border-border-soft rounded-3xl p-[42px] shadow-md-spa">
          <div class="font-serif text-[1.4rem] text-emerald-deep font-semibold mb-6">Send us a message</div>
          <form class="flex flex-col gap-[18px]">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-[18px]">
              <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Your Name
                <input type="text" placeholder="Maria Santos" class="px-4 py-3 border border-border-soft rounded-[10px] font-sans text-[0.92rem] text-ink bg-ivory focus:outline-none focus:border-emerald-brand focus:bg-white focus:shadow-[0_0_0_3px_rgba(0,92,69,.08)] transition-all font-normal" />
              </label>
              <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Spa / Business Name
                <input type="text" placeholder="Bloom Spa" class="px-4 py-3 border border-border-soft rounded-[10px] font-sans text-[0.92rem] text-ink bg-ivory focus:outline-none focus:border-emerald-brand focus:bg-white focus:shadow-[0_0_0_3px_rgba(0,92,69,.08)] transition-all font-normal" />
              </label>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-[18px]">
              <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Email Address
                <input type="email" placeholder="you@spa.com" class="px-4 py-3 border border-border-soft rounded-[10px] font-sans text-[0.92rem] text-ink bg-ivory focus:outline-none focus:border-emerald-brand focus:bg-white focus:shadow-[0_0_0_3px_rgba(0,92,69,.08)] transition-all font-normal" />
              </label>
              <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Phone Number
                <input type="tel" placeholder="+63 912 345 6789" class="px-4 py-3 border border-border-soft rounded-[10px] font-sans text-[0.92rem] text-ink bg-ivory focus:outline-none focus:border-emerald-brand focus:bg-white focus:shadow-[0_0_0_3px_rgba(0,92,69,.08)] transition-all font-normal" />
              </label>
            </div>
            <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">How can we help?
              <select class="px-4 py-3 border border-border-soft rounded-[10px] font-sans text-[0.92rem] text-ink bg-ivory focus:outline-none focus:border-emerald-brand focus:bg-white focus:shadow-[0_0_0_3px_rgba(0,92,69,.08)] transition-all font-normal">
                <option>Schedule a demo</option>
                <option>Pricing questions</option>
                <option>Lifetime ownership inquiry</option>
                <option>Technical support</option>
                <option>Partnership / White-label</option>
                <option>Other</option>
              </select>
            </label>
            <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Your Message
              <textarea rows="5" placeholder="Tell us about your spa, your branches, and what you're looking for in a system..." class="px-4 py-3 border border-border-soft rounded-[10px] font-sans text-[0.92rem] text-ink bg-ivory focus:outline-none focus:border-emerald-brand focus:bg-white focus:shadow-[0_0_0_3px_rgba(0,92,69,.08)] transition-all font-normal resize-y min-h-[120px]"></textarea>
            </label>
            <button type="button" class="btn btn-primary w-full mt-2 py-4 text-[0.95rem]">Send Message →</button>
            <div class="text-center text-[0.78rem] text-muted mt-3 leading-relaxed">We respect your privacy. Your information is never shared with third parties.</div>
          </form>
        </div>

        <div class="flex flex-col gap-[18px]">
          <div class="bg-white border border-border-soft rounded-2xl p-[26px_24px] transition-all hover:-translate-y-0.5 hover:shadow-md-spa">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-emerald-brand/10 to-gold-brand/10 text-emerald-brand flex items-center justify-center mb-3.5 border border-emerald-brand/15">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h4 class="font-serif text-[1.05rem] text-emerald-deep font-semibold mb-1.5">Office</h4>
            <p class="text-[0.9rem] leading-relaxed">123 Wellness Street<br/>Makati City, Philippines 1226</p>
          </div>
          <div class="bg-white border border-border-soft rounded-2xl p-[26px_24px] transition-all hover:-translate-y-0.5 hover:shadow-md-spa">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-emerald-brand/10 to-gold-brand/10 text-emerald-brand flex items-center justify-center mb-3.5 border border-emerald-brand/15">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <h4 class="font-serif text-[1.05rem] text-emerald-deep font-semibold mb-1.5">Phone</h4>
            <p class="text-[0.9rem] leading-relaxed"><a href="tel:+639123456789" class="text-emerald-brand font-medium hover:underline">+63 912 345 6789</a><br/><small class="text-[0.78rem] text-muted/80">Mon–Sat, 9 AM – 6 PM PHT</small></p>
          </div>
          <div class="bg-white border border-border-soft rounded-2xl p-[26px_24px] transition-all hover:-translate-y-0.5 hover:shadow-md-spa">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-emerald-brand/10 to-gold-brand/10 text-emerald-brand flex items-center justify-center mb-3.5 border border-emerald-brand/15">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h4 class="font-serif text-[1.05rem] text-emerald-deep font-semibold mb-1.5">Email</h4>
            <p class="text-[0.9rem] leading-relaxed"><a href="mailto:hello@avaspacentral.com" class="text-emerald-brand font-medium hover:underline">hello@avaspacentral.com</a><br/><a href="mailto:support@avaspacentral.com" class="text-emerald-brand font-medium hover:underline">support@avaspacentral.com</a></p>
          </div>
          <div class="bg-white border border-border-soft rounded-2xl p-[26px_24px] transition-all hover:-translate-y-0.5 hover:shadow-md-spa">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-emerald-brand/10 to-gold-brand/10 text-emerald-brand flex items-center justify-center mb-3.5 border border-emerald-brand/15">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
            </div>
            <h4 class="font-serif text-[1.05rem] text-emerald-deep font-semibold mb-1.5">Office Hours</h4>
            <p class="text-[0.9rem] leading-relaxed">Monday – Friday: 9 AM – 6 PM<br/>Saturday: 10 AM – 4 PM<br/>Sunday: Closed</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- OFFICE / MAP -->
  <section class="py-[90px] bg-cream relative overflow-hidden">
    <SectionDecor orbs={["em-tl","gold-br"]} image="/6-nobg.png" imagePos="tr" />
    <div class="container-spa relative z-[2]">
      <div class="text-center max-w-[620px] mx-auto mb-12 reveal">
        <span class="eyebrow inline-block mb-3.5">Visit Us</span>
        <h2 class="text-emerald-deep mb-3">Our Makati office.</h2>
        <p class="text-base">Drop by for a live walkthrough — we're a few steps from Ayala Avenue.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-[1.1fr_1fr] gap-12 max-w-[1180px] mx-auto items-center reveal">
        <div class="bg-white border border-border-soft rounded-2xl overflow-hidden shadow-md-spa relative aspect-[4/3]">
          <iframe src="https://www.openstreetmap.org/export/embed.html?bbox=121.0260%2C14.5500%2C121.0360%2C14.5600&layer=mapnik&marker=14.5550%2C121.0310" loading="lazy" title="AVA Spa Central office location" class="w-full h-full border-0 block"></iframe>
        </div>
        <div>
          <h3 class="font-serif text-[1.8rem] text-emerald-deep font-semibold mb-3.5 tracking-tight">AVA Spa Central HQ</h3>
          <p class="text-base leading-relaxed mb-3.5">Our team is here to support you in person, online, or over the phone — whichever you prefer.</p>
          <div class="flex items-start gap-3 mb-3"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-[18px] h-[18px] text-emerald-brand flex-shrink-0 mt-0.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg><div class="flex-1"><strong class="block text-ink font-semibold text-[0.92rem] mb-0.5 font-sans">Address</strong><small class="text-[0.86rem] text-muted leading-relaxed block">123 Wellness Street, Makati City, Philippines 1226</small></div></div>
          <div class="flex items-start gap-3 mb-3"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-[18px] h-[18px] text-emerald-brand flex-shrink-0 mt-0.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg><div class="flex-1"><strong class="block text-ink font-semibold text-[0.92rem] mb-0.5 font-sans">Nearby Landmarks</strong><small class="text-[0.86rem] text-muted leading-relaxed block">5 mins from Ayala MRT · Walking distance to Glorietta · BPI building beside</small></div></div>
          <div class="flex items-start gap-3 mb-3"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-[18px] h-[18px] text-emerald-brand flex-shrink-0 mt-0.5"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg><div class="flex-1"><strong class="block text-ink font-semibold text-[0.92rem] mb-0.5 font-sans">Best Time to Visit</strong><small class="text-[0.86rem] text-muted leading-relaxed block">Walk-in welcome Tue–Fri, 10 AM – 4 PM. For demos, please book ahead.</small></div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL -->
  <section class="py-[90px] bg-ivory text-center relative overflow-hidden">
    <SectionDecor orbs={["gold-tr","em-bl"]} image="/7-nobg.png" imagePos="bl" />
    <div class="container-spa relative z-[2]">
      <span class="eyebrow inline-block mb-3.5">Faster Replies</span>
      <h2 class="text-emerald-deep mb-3.5">Or message us directly.</h2>
      <p class="text-base max-w-[520px] mx-auto mb-9">Chat with our team on your preferred platform — we usually respond within minutes during business hours.</p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="#" class="w-[140px] p-[24px_18px] bg-white border border-border-soft rounded-2xl no-underline flex flex-col items-center gap-2.5 transition-all hover:-translate-y-1 hover:shadow-md-spa hover:border-emerald-brand">
          <div class="w-[42px] h-[42px] rounded-xl flex items-center justify-center text-white bg-[#1877F2]"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg></div>
          <span class="text-[0.82rem] text-ink font-semibold">Facebook</span>
          <small class="text-[0.7rem] text-muted font-medium">@avaspacentral</small>
        </a>
        <a href="#" class="w-[140px] p-[24px_18px] bg-white border border-border-soft rounded-2xl no-underline flex flex-col items-center gap-2.5 transition-all hover:-translate-y-1 hover:shadow-md-spa hover:border-emerald-brand">
          <div class="w-[42px] h-[42px] rounded-xl flex items-center justify-center text-white" style="background:linear-gradient(135deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></div>
          <span class="text-[0.82rem] text-ink font-semibold">Instagram</span>
          <small class="text-[0.7rem] text-muted font-medium">@avaspacentral</small>
        </a>
        <a href="#" class="w-[140px] p-[24px_18px] bg-white border border-border-soft rounded-2xl no-underline flex flex-col items-center gap-2.5 transition-all hover:-translate-y-1 hover:shadow-md-spa hover:border-emerald-brand">
          <div class="w-[42px] h-[42px] rounded-xl flex items-center justify-center text-white bg-[#0084FF]"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.36 2 2 6.13 2 11.7c0 2.91 1.19 5.44 3.14 7.17.16.14.26.34.27.55l.05 1.78a.8.8 0 0 0 1.12.71l1.99-.88c.16-.07.34-.08.5-.04.91.25 1.88.39 2.93.39 5.64 0 10-4.13 10-9.7C22 6.13 17.64 2 12 2z"/></svg></div>
          <span class="text-[0.82rem] text-ink font-semibold">Messenger</span>
          <small class="text-[0.7rem] text-muted font-medium">Tap to chat</small>
        </a>
        <a href="#" class="w-[140px] p-[24px_18px] bg-white border border-border-soft rounded-2xl no-underline flex flex-col items-center gap-2.5 transition-all hover:-translate-y-1 hover:shadow-md-spa hover:border-emerald-brand">
          <div class="w-[42px] h-[42px] rounded-xl flex items-center justify-center text-white bg-[#7360F2]"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6 2 11c0 2.5 1.5 5 4 6.5L5 22l4.5-2c.8.2 1.7.3 2.5.3 5.5 0 10-4 10-9.3S17.5 2 12 2z"/></svg></div>
          <span class="text-[0.82rem] text-ink font-semibold">Viber</span>
          <small class="text-[0.7rem] text-muted font-medium">+63 912 345 6789</small>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-[100px] bg-cream relative overflow-hidden">
    <SectionDecor orbs={["em-tl","gold-br"]} image="/8-nobg.png" imagePos="br" />
    <div class="container-spa relative z-[2]">
      <div class="text-center max-w-[620px] mx-auto mb-12 reveal">
        <span class="eyebrow inline-block mb-3.5">Quick Answers</span>
        <h2 class="text-emerald-deep mb-3">Before you message us…</h2>
      </div>
      <div class="max-w-[820px] mx-auto flex flex-col gap-3 reveal">
        <FaqItem q="How fast do you respond?">Within one business day, usually much sooner. Messages sent on Facebook or Messenger during business hours often get a reply in under 15 minutes.</FaqItem>
        <FaqItem q="Can I get a live demo of AVA?">Yes — schedule one through the form above or chat with us on social. Demos run about 30 minutes and cover booking, POS, monitoring, and reports.</FaqItem>
        <FaqItem q="Do you serve spas outside Metro Manila?">Absolutely. AVA Spa Central is cloud-based and works anywhere in the Philippines with an internet connection. We have clients from Baguio to Davao.</FaqItem>
        <FaqItem q="Can I visit your office without an appointment?">Yes — walk-ins are welcome Tuesday to Friday, 10 AM to 4 PM. For dedicated demo sessions, we recommend booking ahead so we can prepare your use case.</FaqItem>
        <FaqItem q="Do you offer phone support?">Yes. Call +63 912 345 6789 Monday to Saturday between 9 AM and 6 PM. Enterprise and Lifetime customers also get a dedicated support line.</FaqItem>
      </div>
    </div>
  </section>

</Layout>
