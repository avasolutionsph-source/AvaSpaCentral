# Marketing site environment variables.
# Copy to .env for local development. Set the production values in
# Netlify Site settings → Build & deploy → Environment.

# Where the spa PWA (the customer-facing app) is hosted. The checkout
# success / building pages link the "Install AVA App" CTA to
# ${PUBLIC_SPA_APP_URL}/install.
#
# Local dev (when running `cd ../spa-app && npm run dev`):
PUBLIC_SPA_APP_URL=http://localhost:3000
#
# Example production value:
# PUBLIC_SPA_APP_URL=https://app.avaspacentral.com
