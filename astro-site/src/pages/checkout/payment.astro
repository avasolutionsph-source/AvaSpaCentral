---
import Layout from '../../layouts/Layout.astro';

const methods = [
  {
    id: 'gcash',
    name: 'GCash',
    desc: 'Pay using your GCash wallet — instant confirmation.',
    badge: 'Most popular',
    iconBg: 'bg-blue-50',
    iconColor: 'text-blue-600',
  },
  {
    id: 'maya',
    name: 'Maya',
    desc: 'Pay via Maya wallet or Maya account balance.',
    iconBg: 'bg-emerald-50',
    iconColor: 'text-emerald-700',
  },
  {
    id: 'card',
    name: 'Credit / Debit Card',
    desc: 'Visa, Mastercard, and JCB cards accepted.',
    iconBg: 'bg-gold-soft/30',
    iconColor: 'text-gold-brand',
  },
  {
    id: 'bank',
    name: 'Online Bank Transfer',
    desc: 'BPI, BDO, UnionBank, Metrobank and more.',
    iconBg: 'bg-ivory',
    iconColor: 'text-emerald-brand',
  },
  {
    id: 'otc',
    name: 'Over-the-Counter',
    desc: '7-Eleven, M Lhuillier, Cebuana — pay in person.',
    iconBg: 'bg-cream',
    iconColor: 'text-emerald-deep',
  },
];
---

<Layout title="Payment — AVA Spa Central" description="Choose your payment method to complete your AVA Spa Central subscription.">

  <!-- HEADER -->
  <section class="pt-[80px] pb-10 bg-ivory" style="background: radial-gradient(circle at 15% 30%, rgba(0,92,69,.05) 0%, transparent 38%), radial-gradient(circle at 85% 70%, rgba(201,154,58,.06) 0%, transparent 42%), var(--color-ivory);">
    <div class="container-spa">
      <div class="max-w-[680px]">
        <span class="eyebrow inline-block mb-3">Step 2 of 3 · Payment Method</span>
        <h1 class="mb-3 text-[clamp(2rem,4vw,2.8rem)]">Choose how you want to <span class="italic text-emerald-brand font-medium">pay.</span></h1>
        <p class="text-base max-w-[520px] leading-relaxed">Secured by NextPay — kahit anong method, mabilis at safe ang processing.</p>
      </div>
      <div class="flex items-center gap-3 mt-8 max-w-[520px]">
        <div class="flex-1 h-1 rounded-full bg-emerald-brand"></div>
        <div class="flex-1 h-1 rounded-full bg-emerald-brand"></div>
        <div class="flex-1 h-1 rounded-full bg-border-soft"></div>
      </div>
    </div>
  </section>

  <!-- PAYMENT -->
  <section class="py-[60px]">
    <div class="container-spa">
      <div class="grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-10 items-start">

        <!-- QR PANEL (hidden until real NextPay flow creates an intent) -->
        <div id="qrPanel" class="hidden bg-white border border-border-soft rounded-2xl p-8 md:p-10 shadow-md-spa">
          <h3 class="font-serif text-[1.4rem] text-emerald-deep font-semibold mb-1.5">Scan to Pay</h3>
          <p class="text-[0.88rem] text-muted mb-6">Buksan ang <span id="qrMethodLabel" class="font-semibold text-ink">GCash / Maya</span> app, i-scan ang QR code, at i-confirm ang bayad.</p>

          <div class="flex flex-col items-center gap-5 mb-6">
            <div id="qrCanvasWrap" class="w-[280px] h-[280px] bg-white border border-border-soft rounded-xl flex items-center justify-center p-3">
              <span id="qrLoading" class="text-[0.88rem] text-muted">Generating QR…</span>
              <img id="qrImage" alt="NextPay QR code" class="hidden w-full h-full object-contain" />
            </div>
            <p class="text-[0.86rem] text-muted text-center">
              Total: <span id="qrAmount" class="font-semibold text-emerald-deep">—</span>
              <span class="mx-1.5 text-border-soft">·</span>
              Expires in <span id="qrCountdown" class="font-semibold text-emerald-deep tabular-nums">—</span>
            </p>
          </div>

          <div class="flex items-start gap-3 p-4 bg-ivory border border-border-soft rounded-xl mb-7">
            <span class="w-3 h-3 mt-1 rounded-full bg-emerald-brand animate-pulse flex-shrink-0"></span>
            <div>
              <p class="text-[0.86rem] text-ink font-semibold mb-1">Naghihintay ng bayad…</p>
              <p class="text-[0.82rem] text-muted leading-relaxed">Pagkatapos mong i-confirm sa wallet app mo, awtomatiko kang dadalhin sa next step. Huwag i-close ang page na ito.</p>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 items-center sm:justify-between">
            <button id="qrCancelBtn" type="button" class="text-[0.88rem] text-muted hover:text-emerald-brand transition-colors">← Pumili ng ibang method</button>
            <span id="qrStatusText" class="text-[0.82rem] text-muted">Status: pending</span>
          </div>
        </div>

        <!-- METHODS -->
        <form id="paymentForm" class="bg-white border border-border-soft rounded-2xl p-8 md:p-10 shadow-md-spa">
          <h3 class="font-serif text-[1.4rem] text-emerald-deep font-semibold mb-1.5">Payment Method</h3>
          <p class="text-[0.88rem] text-muted mb-6">Pumili ng method. Magre-redirect kami sa NextPay para sa secure processing.</p>

          <div class="flex flex-col gap-3 mb-8">
            {methods.map((m, i) => (
              <label class={`flex items-center gap-4 p-4 border rounded-xl cursor-pointer transition-all hover:border-emerald-brand has-checked:border-emerald-brand has-checked:bg-emerald-brand/[0.03] ${i === 0 ? 'border-emerald-brand bg-emerald-brand/[0.03]' : 'border-border-soft'}`}>
                <input type="radio" name="method" value={m.id} required checked={i === 0} class="w-4 h-4 accent-emerald-brand"/>
                <div class={`w-11 h-11 rounded-lg flex items-center justify-center ${m.iconBg} ${m.iconColor}`}>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5">
                    {m.id === 'gcash' && <><rect x="2" y="6" width="20" height="13" rx="2"/><circle cx="12" cy="12.5" r="2.5"/></>}
                    {m.id === 'maya' && <><rect x="2" y="6" width="20" height="13" rx="2"/><path d="M2 11h20"/></>}
                    {m.id === 'card' && <><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/><path d="M6 15h4"/></>}
                    {m.id === 'bank' && <><path d="M3 21h18"/><path d="M5 21V10l7-5 7 5v11"/><path d="M9 21v-7"/><path d="M15 21v-7"/></>}
                    {m.id === 'otc' && <><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></>}
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-0.5">
                    <strong class="text-ink text-[0.95rem] font-semibold">{m.name}</strong>
                    {m.badge && <span class="text-[0.66rem] uppercase tracking-wider bg-emerald-brand/10 text-emerald-brand px-2 py-0.5 rounded font-bold">{m.badge}</span>}
                  </div>
                  <p class="text-[0.82rem] text-muted leading-snug">{m.desc}</p>
                </div>
              </label>
            ))}
          </div>

          <!-- Notice -->
          <div class="flex items-start gap-3 p-4 bg-ivory border border-border-soft rounded-xl mb-7">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5 text-emerald-brand flex-shrink-0 mt-0.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><circle cx="12" cy="16" r="0.5" fill="currentColor"/></svg>
            <div>
              <p class="text-[0.86rem] text-ink font-semibold mb-1">Sandali lang sa NextPay</p>
              <p class="text-[0.82rem] text-muted leading-relaxed">Pagkatapos mong i-click ang Pay Now, magre-redirect ka sa NextPay's secure payment page. Babalik ka dito kapag tapos na ang bayad.</p>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 items-center sm:justify-between">
            <a href="/checkout" class="text-[0.88rem] text-muted hover:text-emerald-brand transition-colors">← Back to Account Details</a>
            <button type="submit" id="payBtn" class="btn btn-primary px-9">
              <span id="payBtnLabel">Pay <span id="payAmount">—</span> →</span>
              <span id="payBtnSpinner" class="hidden">Processing…</span>
            </button>
          </div>
        </form>

        <!-- ORDER SUMMARY -->
        <aside class="lg:sticky lg:top-[100px]">
          <div class="bg-emerald-deep text-white rounded-2xl p-7 shadow-lg-spa relative overflow-hidden">
            <div class="absolute top-0 right-0 w-40 h-40 rounded-full" style="background: radial-gradient(circle, rgba(201,154,58,.18) 0%, transparent 60%); transform: translate(40%, -40%);"></div>
            <div class="relative z-[1]">
              <span class="eyebrow !text-gold-soft mb-3 block">Order Summary</span>
              <h3 id="planName" class="font-serif text-[1.8rem] font-semibold !text-white mb-1.5 tracking-tight">—</h3>

              <div class="bg-white/[0.06] border border-white/10 rounded-lg p-4 mb-5">
                <p class="text-[0.74rem] uppercase tracking-wider !text-white/55 mb-1.5 font-semibold">Customer</p>
                <p id="customerBusiness" class="!text-white text-[0.95rem] font-semibold mb-0.5">—</p>
                <p id="customerEmail" class="!text-white/65 text-[0.84rem]">—</p>
              </div>

              <hr class="border-white/15 mb-5"/>

              <div class="flex justify-between items-baseline mb-1.5">
                <span class="text-[0.88rem] !text-white/70">Plan (monthly)</span>
                <span id="planPrice" class="!text-white font-semibold">—</span>
              </div>
              <div class="flex justify-between items-baseline mb-4">
                <span class="text-[0.88rem] !text-white/70">VAT (incl.)</span>
                <span class="!text-white/70 text-[0.88rem]">—</span>
              </div>
              <div class="flex justify-between items-baseline pt-3 border-t border-white/15">
                <span class="font-semibold !text-white">Total today</span>
                <span id="totalAmount" class="font-serif text-[1.5rem] !text-gold-soft font-semibold">—</span>
              </div>

              <p class="text-[0.78rem] !text-white/55 mt-5 leading-relaxed">Recurring monthly. Cancel anytime mula sa dashboard.</p>
            </div>
          </div>

          <div class="flex items-center gap-3 justify-center mt-5 text-[0.78rem] text-muted">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-4 h-4 text-emerald-brand"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span>256-bit SSL · NextPay secured</span>
          </div>
        </aside>

      </div>
    </div>
  </section>

</Layout>

<!-- QR generation: tiny vanilla library, ~3KB. Loaded only on this page so
     dev-mode flow (which never renders a QR) doesn't pay the cost. -->
<script is:inline src="https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js"></script>

<script is:inline>
  // Two ways to arrive here:
  //   1. Step 1 (index.astro) called /api/create-checkout-session and the
  //      server's paymentUrl led here with ?session=<token>. ava_checkout in
  //      sessionStorage has the same token + UI labels.
  //   2. Step 1 sessionStorage exists but the URL is bare (defensive — older
  //      tabs, manual nav). Fall back to the stashed token.
  const params = new URLSearchParams(window.location.search);
  const tokenFromUrl = params.get('session');
  const raw = sessionStorage.getItem('ava_checkout');
  const stash = raw ? JSON.parse(raw) : null;
  const token = tokenFromUrl || stash?.token;

  if (!token) {
    window.location.href = '/checkout';
  } else {
    const planName = stash?.planName || '—';
    const planPrice = stash?.planPrice || '—';
    const businessName = stash?.businessName || '—';
    const email = stash?.email || '—';
    const devMode = !!stash?.devMode;

    document.getElementById('planName').textContent = planName;
    document.getElementById('planPrice').textContent = planPrice;
    document.getElementById('totalAmount').textContent = planPrice;
    document.getElementById('payAmount').textContent = planPrice;
    document.getElementById('customerBusiness').textContent = businessName;
    document.getElementById('customerEmail').textContent = email;

    const form = document.getElementById('paymentForm');
    const payBtn = document.getElementById('payBtn');
    const payBtnLabel = document.getElementById('payBtnLabel');
    const payBtnSpinner = document.getElementById('payBtnSpinner');
    const qrPanel = document.getElementById('qrPanel');
    const qrImage = document.getElementById('qrImage');
    const qrLoading = document.getElementById('qrLoading');
    const qrAmount = document.getElementById('qrAmount');
    const qrCountdown = document.getElementById('qrCountdown');
    const qrMethodLabel = document.getElementById('qrMethodLabel');
    const qrStatusText = document.getElementById('qrStatusText');
    const qrCancelBtn = document.getElementById('qrCancelBtn');

    if (devMode) {
      const label = document.getElementById('payBtnLabel');
      label.innerHTML = 'Simulate Payment <span id="payAmount">' + planPrice + '</span> → (Dev Mode)';
    }

    function resetPayButton() {
      payBtnLabel.classList.remove('hidden');
      payBtnSpinner.classList.add('hidden');
      payBtn.disabled = false;
    }

    function methodLabel(method) {
      switch (method) {
        case 'gcash': return 'GCash';
        case 'maya':  return 'Maya';
        case 'qrph':  return 'QRPh';
        default:      return String(method || '');
      }
    }

    // Render the QR string returned by NextPay into the on-page <img>.
    // Prefers NextPay's own qr_image_url when supplied (preserves their
    // exact rendering); falls back to local generation via qrcode-generator
    // so we never block on a missing image URL.
    function renderQr({ qrString, qrImageUrl }) {
      qrLoading.classList.add('hidden');
      qrImage.classList.remove('hidden');
      if (qrImageUrl) {
        qrImage.src = qrImageUrl;
        return;
      }
      // qrcode-generator uses error-correction levels 'L'|'M'|'Q'|'H'. 'M'
      // is the standard for QRPh; type number 0 = auto-fit to data length.
      // eslint-disable-next-line no-undef
      const qr = qrcode(0, 'M');
      qr.addData(qrString);
      qr.make();
      qrImage.src = qr.createDataURL(6, 4);
    }

    function startCountdown(expiresAtIso) {
      const expiresAt = new Date(expiresAtIso).getTime();
      const tick = () => {
        const ms = Math.max(0, expiresAt - Date.now());
        const totalSeconds = Math.floor(ms / 1000);
        const m = Math.floor(totalSeconds / 60);
        const s = String(totalSeconds % 60).padStart(2, '0');
        qrCountdown.textContent = `${m}:${s}`;
        if (ms <= 0) clearInterval(handle);
      };
      tick();
      const handle = setInterval(tick, 1000);
      return handle;
    }

    // Poll /api/check-provisioning-status until status leaves 'pending'.
    // 'paid' or 'provisioned' → forward to /checkout/building (which has
    // its own polling for the provisioning animation). 'failed'/'expired'
    // → surface inline so the customer can retry.
    async function pollUntilPaid() {
      const TIMEOUT_MS = 16 * 60_000; // outlast the 15-min QR
      const start = Date.now();
      while (true) {
        if (Date.now() - start > TIMEOUT_MS) return { status: 'timeout' };
        try {
          const res = await fetch(`/api/check-provisioning-status?token=${encodeURIComponent(token)}`);
          if (res.ok) {
            const data = await res.json();
            if (data.status && data.status !== 'pending') return data;
            qrStatusText.textContent = `Status: ${data.status || 'pending'}`;
          }
        } catch {
          // swallow — transient network blip; keep polling
        }
        await new Promise((r) => setTimeout(r, 2000));
      }
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const method = String(new FormData(form).get('method') || '');

      payBtn.disabled = true;
      payBtnLabel.classList.add('hidden');
      payBtnSpinner.classList.remove('hidden');

      sessionStorage.setItem('ava_checkout_method', method);

      if (devMode) {
        // Dev-mode shortcut: POST straight to the webhook endpoint with the
        // session token. Skips NextPay entirely.
        try {
          const res = await fetch('/api/nextpay-webhook', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ token, method }),
          });
          const result = await res.json().catch(() => ({}));
          if (!res.ok) {
            resetPayButton();
            alert('Payment simulation failed: ' + (result?.detail || result?.error || 'unknown error'));
            return;
          }
        } catch (err) {
          resetPayButton();
          alert('Network error during payment simulation. Please try again.');
          return;
        }
        window.location.href = `/checkout/building?session=${encodeURIComponent(token)}`;
        return;
      }

      // Real NextPay path: ask the server to mint a payment intent, swap
      // the form for the QR panel, and poll for status until the customer
      // pays. When paid, the server-side webhook fires provisioning and
      // /checkout/building takes over the post-payment animation.
      let intent;
      try {
        const res = await fetch('/api/create-payment-intent', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, method }),
        });
        intent = await res.json().catch(() => ({}));
        if (!res.ok) {
          resetPayButton();
          if (intent?.error === 'method_not_supported') {
            alert(intent.detail || 'This payment method is not yet supported. Pick GCash or Maya for now.');
          } else if (intent?.error === 'session_not_pending' && intent?.status) {
            window.location.href = `/checkout/building?session=${encodeURIComponent(token)}`;
          } else {
            alert('Could not start payment: ' + (intent?.detail || intent?.error || 'unknown error'));
          }
          return;
        }
      } catch (err) {
        resetPayButton();
        alert('Network error starting payment. Please try again.');
        return;
      }

      form.classList.add('hidden');
      qrPanel.classList.remove('hidden');
      qrAmount.textContent = planPrice;
      qrMethodLabel.textContent = methodLabel(method);
      renderQr({ qrString: intent.qrString, qrImageUrl: intent.qrImageUrl });
      const countdownHandle = startCountdown(intent.expiresAt);

      qrCancelBtn.addEventListener('click', () => {
        // Best-effort UX: let the customer go back and pick a different
        // method. The pending checkout_sessions row stays valid until its
        // 30-min TTL; create-payment-intent will refuse to issue a second
        // intent for the same session, so they can either pay this QR or
        // start a fresh checkout from /checkout.
        clearInterval(countdownHandle);
        form.classList.remove('hidden');
        qrPanel.classList.add('hidden');
        resetPayButton();
      });

      const result = await pollUntilPaid();
      clearInterval(countdownHandle);
      if (result.status === 'paid' || result.status === 'provisioned') {
        window.location.href = `/checkout/building?session=${encodeURIComponent(token)}`;
      } else if (result.status === 'failed' || result.status === 'expired') {
        qrStatusText.textContent = `Status: ${result.status} — ${result.failureReason || 'please try again'}`;
      } else {
        qrStatusText.textContent = 'Status: timeout — refresh and try again';
      }
    });
  }
</script>

<style>
  /* Tailwind has-checked workaround for radio cards */
  label:has(input[type="radio"]:checked) {
    border-color: var(--color-emerald-brand);
    background: rgba(0, 92, 69, 0.03);
  }
</style>
