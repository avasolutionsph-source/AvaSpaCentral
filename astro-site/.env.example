# Marketing site environment variables.
# Copy to .env for local development. Set the production values in
# Netlify Site settings → Build & deploy → Environment.

# Where the spa PWA (the customer-facing app) is hosted. The checkout
# success / building pages link the "Install AVA App" CTA to
# ${PUBLIC_SPA_APP_URL}/install, and the provisioning functions use the
# same value to construct the per-tenant booking URL.
#
# Local dev (when running `cd ../spa-app && npm run dev`):
PUBLIC_SPA_APP_URL=http://localhost:3000
#
# Example production value:
# PUBLIC_SPA_APP_URL=https://spacentralapp.avasolutions.ph

# --- Server-only (Netlify Functions). NEVER expose to the browser. ---

# Supabase service-role key. Used by the checkout / provisioning functions
# to create auth users and insert tenant rows while bypassing RLS. Treat
# as a database password.
SUPABASE_URL=https://idoywgbrtavmzlumwido.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# NextPay credentials. Leave NEXTPAY_CLIENT_SECRET unset to run the
# checkout flow in dev mode (the marketing site renders a "Pay (simulate)"
# button that calls the webhook directly with no real charge). Set both
# values + the webhook secret to flip into real billing.
NEXTPAY_CLIENT_KEY=
NEXTPAY_CLIENT_SECRET=
NEXTPAY_WEBHOOK_SECRET=
NEXTPAY_ENV=test

# Optional soft gate for the dev-mode webhook. If set, the marketing site
# must include the same value in its mock-pay POST. Acts as a "don't fire
# this by accident" check during testing; not a security boundary.
CHECKOUT_DEV_KEY=
