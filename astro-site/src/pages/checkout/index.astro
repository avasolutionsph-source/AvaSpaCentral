---
import Layout from '../../layouts/Layout.astro';

const spaAppUrl = import.meta.env.PUBLIC_SPA_APP_URL || 'http://localhost:3000';

const plans = {
  starter: {
    slug: 'starter',
    name: 'Starter',
    desc: 'Perfect for single-branch spas.',
    regular: '₱3,400',
    promo: '₱1,700',
    feats: [
      '1 Branch Only',
      '1 Login Account (Owner Only)',
      'Shared Tablet Time In/Out for Staff',
    ],
  },
  advance: {
    slug: 'advance',
    name: 'Advance',
    desc: 'Perfect for growing spa businesses.',
    regular: '₱17,000',
    promo: '₱8,500',
    feats: [
      '2 – 3 Branches',
      'Multi-user Accounts',
    ],
  },
  enterprise: {
    slug: 'enterprise',
    name: 'Enterprise',
    desc: 'Perfect for large spa operations.',
    regular: '₱33,000',
    promo: '₱16,500',
    feats: [
      '4 or More Branches',
      'Multi-user Accounts',
      'Priority Support',
    ],
  },
};
---

<Layout title="Checkout — AVA Spa Central" description="Complete your subscription to AVA Spa Central. Secure checkout powered by NextPay.">

  <!-- HEADER -->
  <section class="pt-[80px] pb-10 bg-ivory" style="background: radial-gradient(circle at 15% 30%, rgba(0,92,69,.05) 0%, transparent 38%), radial-gradient(circle at 85% 70%, rgba(201,154,58,.06) 0%, transparent 42%), var(--color-ivory);">
    <div class="container-spa">
      <div class="max-w-[680px]">
        <span class="eyebrow inline-block mb-3">Step 1 of 3 · Account Details</span>
        <h1 class="mb-3 text-[clamp(2rem,4vw,2.8rem)]">Set up your <span class="italic text-emerald-brand font-medium">AVA account.</span></h1>
        <p class="text-base max-w-[520px] leading-relaxed">Tell us about your business and create your login. Mabilis lang — under two minutes ito.</p>
      </div>
      <!-- Progress -->
      <div class="flex items-center gap-3 mt-8 max-w-[520px]">
        <div class="flex-1 h-1 rounded-full bg-emerald-brand"></div>
        <div class="flex-1 h-1 rounded-full bg-border-soft"></div>
        <div class="flex-1 h-1 rounded-full bg-border-soft"></div>
      </div>
    </div>
  </section>

  <!-- CHECKOUT -->
  <section class="py-[60px]">
    <div class="container-spa">
      <div class="grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-10 items-start">

        <!-- FORM -->
        <form id="checkoutForm" class="bg-white border border-border-soft rounded-2xl p-8 md:p-10 shadow-md-spa">
          <!-- Account section -->
          <div class="mb-9">
            <h3 class="font-serif text-[1.4rem] text-emerald-deep font-semibold mb-1.5">Account Login</h3>
            <p class="text-[0.88rem] text-muted mb-5">Email at password mo para sa AVA dashboard.</p>
            <div class="grid grid-cols-1 gap-4">
              <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Email Address
                <input type="email" name="email" required autocomplete="email" placeholder="you@yourspa.com" class="bg-ivory border border-border-soft rounded-lg px-4 py-3 text-[0.95rem] font-normal text-ink focus:outline-none focus:border-emerald-brand transition-colors"/>
              </label>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Password
                  <input type="password" name="password" required minlength="8" autocomplete="new-password" placeholder="At least 8 characters" class="bg-ivory border border-border-soft rounded-lg px-4 py-3 text-[0.95rem] font-normal text-ink focus:outline-none focus:border-emerald-brand transition-colors"/>
                </label>
                <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Confirm Password
                  <input type="password" name="passwordConfirm" required minlength="8" autocomplete="new-password" placeholder="Re-enter password" class="bg-ivory border border-border-soft rounded-lg px-4 py-3 text-[0.95rem] font-normal text-ink focus:outline-none focus:border-emerald-brand transition-colors"/>
                </label>
              </div>
              <p id="passwordError" class="hidden text-[0.82rem] text-red-600 -mt-1">Passwords do not match.</p>
            </div>
          </div>

          <hr class="border-border-soft mb-9"/>

          <!-- Business section -->
          <div class="mb-9">
            <h3 class="font-serif text-[1.4rem] text-emerald-deep font-semibold mb-1.5">Business Information</h3>
            <p class="text-[0.88rem] text-muted mb-5">Para sa receipt at sa setup ng spa profile mo.</p>
            <div class="grid grid-cols-1 gap-4">
              <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Spa / Business Name
                <input type="text" name="businessName" required placeholder="e.g. Serenity Wellness Spa" class="bg-ivory border border-border-soft rounded-lg px-4 py-3 text-[0.95rem] font-normal text-ink focus:outline-none focus:border-emerald-brand transition-colors"/>
              </label>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Owner Full Name
                  <input type="text" name="ownerName" required placeholder="Juan Dela Cruz" class="bg-ivory border border-border-soft rounded-lg px-4 py-3 text-[0.95rem] font-normal text-ink focus:outline-none focus:border-emerald-brand transition-colors"/>
                </label>
                <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Mobile Number
                  <input type="tel" name="phone" required pattern="[0-9+\-\s]{7,}" placeholder="+63 9XX XXX XXXX" class="bg-ivory border border-border-soft rounded-lg px-4 py-3 text-[0.95rem] font-normal text-ink focus:outline-none focus:border-emerald-brand transition-colors"/>
                </label>
              </div>
              <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Business Address
                <input type="text" name="address" required placeholder="City, Province" class="bg-ivory border border-border-soft rounded-lg px-4 py-3 text-[0.95rem] font-normal text-ink focus:outline-none focus:border-emerald-brand transition-colors"/>
              </label>
              <label class="flex flex-col gap-2 text-[0.78rem] font-semibold text-ink">Number of Branches
                <input id="branchesInput" type="number" name="branches" required min="1" value="1" class="bg-ivory border border-border-soft rounded-lg px-4 py-3 text-[0.95rem] font-normal text-ink focus:outline-none focus:border-emerald-brand transition-colors w-32"/>
                <span id="branchesHint" class="text-[0.78rem] font-normal text-muted"></span>
              </label>
            </div>
          </div>

          <hr class="border-border-soft mb-7"/>

          <!-- Terms -->
          <label class="flex items-start gap-3 mb-7 cursor-pointer">
            <input type="checkbox" name="terms" required class="mt-1 w-4 h-4 accent-emerald-brand"/>
            <span class="text-[0.86rem] text-muted leading-relaxed">I agree to the <button type="button" data-open-legal="terms" class="text-emerald-brand hover:underline cursor-pointer">Terms of Service</button> and <button type="button" data-open-legal="privacy" class="text-emerald-brand hover:underline cursor-pointer">Privacy Policy</button>.</span>
          </label>

          <!-- Submit -->
          <div class="flex flex-col sm:flex-row gap-3 items-center sm:justify-between">
            <a href="/pricing" class="text-[0.88rem] text-muted hover:text-emerald-brand transition-colors">← Back to Pricing</a>
            <button type="submit" class="btn btn-primary px-9">Continue to Payment →</button>
          </div>
        </form>

        <!-- ORDER SUMMARY -->
        <aside class="lg:sticky lg:top-[100px]">
          <div class="bg-emerald-deep text-white rounded-2xl p-7 shadow-lg-spa relative overflow-hidden">
            <div class="absolute top-0 right-0 w-40 h-40 rounded-full" style="background: radial-gradient(circle, rgba(201,154,58,.18) 0%, transparent 60%); transform: translate(40%, -40%);"></div>
            <div class="relative z-[1]">
              <span class="eyebrow !text-gold-soft mb-3 block">Order Summary</span>
              <h3 id="planName" class="font-serif text-[1.8rem] font-semibold !text-white mb-1.5 tracking-tight">—</h3>
              <p id="planDesc" class="text-[0.88rem] !text-white/70 mb-6">—</p>

              <div class="flex items-baseline gap-2 mb-1">
                <span id="planPromo" class="font-serif text-[2.4rem] !text-gold-soft font-semibold leading-none">—</span>
                <span class="text-[0.7rem] uppercase tracking-wider !text-white/55 font-semibold">/ month</span>
              </div>
              <div class="flex items-center gap-2 mb-6">
                <span id="planRegular" class="text-[0.86rem] !text-white/45 line-through">—</span>
                <span class="text-[0.7rem] uppercase tracking-wider bg-gold-brand/30 text-gold-soft px-2 py-0.5 rounded font-semibold">50% OFF</span>
              </div>

              <h4 class="text-[0.72rem] uppercase tracking-wider !text-gold-soft font-bold mb-3">What's Included</h4>
              <ul id="planFeats" class="list-none flex flex-col gap-2 m-0 p-0 mb-6"></ul>

              <hr class="border-white/15 mb-5"/>

              <div class="flex justify-between items-baseline mb-1.5">
                <span class="text-[0.88rem] !text-white/70">Subtotal</span>
                <span id="subtotal" class="!text-white font-semibold">—</span>
              </div>
              <div class="flex justify-between items-baseline mb-4">
                <span class="text-[0.88rem] !text-white/70">VAT (incl.)</span>
                <span class="!text-white/70 text-[0.88rem]">—</span>
              </div>
              <div class="flex justify-between items-baseline pt-3 border-t border-white/15">
                <span class="font-semibold !text-white">Total today</span>
                <span id="total" class="font-serif text-[1.5rem] !text-gold-soft font-semibold">—</span>
              </div>

              <p class="text-[0.78rem] !text-white/55 mt-5 leading-relaxed">Secure payment via NextPay. Cancel anytime — walang lock-in.</p>
            </div>
          </div>

          <div class="flex items-center gap-3 justify-center mt-5 text-[0.78rem] text-muted">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-4 h-4 text-emerald-brand"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span>256-bit SSL · NextPay secured</span>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ========================================================== -->
  <!-- LEGAL MODALS: Terms of Service + Privacy Policy             -->
  <!-- ========================================================== -->
  <!-- Hidden by default; opened by the [data-open-legal] buttons  -->
  <!-- in the checkout consent line. The same markup is used for   -->
  <!-- both — only the inner content panel switches via id.        -->

  <div id="legalModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/55 p-4 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="legalModalTitle">
    <div class="bg-ivory border border-border-soft rounded-2xl shadow-lg-spa w-full max-w-[760px] max-h-[88vh] flex flex-col overflow-hidden relative">
      <!-- Header -->
      <div class="flex items-center justify-between gap-3 px-7 py-5 border-b border-border-soft bg-white">
        <div>
          <span class="eyebrow inline-block mb-1.5" id="legalModalEyebrow">Legal</span>
          <h2 id="legalModalTitle" class="font-serif text-[1.5rem] text-emerald-deep font-semibold tracking-tight m-0">Terms of Service</h2>
        </div>
        <button type="button" id="legalModalClose" aria-label="Close" class="w-9 h-9 rounded-full border border-border-soft bg-white hover:bg-ivory text-muted hover:text-ink transition-colors flex items-center justify-center text-[1.1rem] leading-none flex-shrink-0">×</button>
      </div>

      <!-- Scrollable body — content swapped based on which link was clicked -->
      <div class="flex-1 overflow-y-auto px-7 py-6">

        <!-- TERMS OF SERVICE -->
        <article id="legalContent-terms" class="legal-prose text-[0.92rem] leading-relaxed text-ink hidden">
          <p class="text-[0.78rem] uppercase tracking-wider text-muted font-semibold mb-4">Last updated: May 2026</p>
          <p class="mb-4">These Terms of Service (the <strong>"Terms"</strong>) govern your access to and use of the AVA Spa Central platform (the <strong>"Service"</strong>) operated by <strong>AVA Solutions PH</strong> (<strong>"AVA"</strong>, <strong>"we"</strong>, <strong>"us"</strong>). By creating an account or paying for a subscription, you (<strong>"Customer"</strong>) agree to be bound by these Terms. If you do not agree, do not use the Service.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">1. The Service</h3>
          <p class="mb-3">AVA Spa Central is a cloud-based spa-management platform that provides booking, point-of-sale, inventory, payroll, customer management, analytics, and related operational tooling for spa businesses in the Philippines. Features available to your account are determined by the subscription plan tier you select (Starter, Advance, or Enterprise).</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">2. Accounts and authorised users</h3>
          <p class="mb-3">You are responsible for the accuracy of the information provided at sign-up, for safeguarding your password and any access tokens, and for all activity that occurs under your account. The Starter plan permits one (1) Owner login only; Advance and Enterprise permit multiple staff logins as configured by the Owner. You must notify us immediately at <a href="mailto:hello@avaspacentral.com" class="text-emerald-brand underline">hello@avaspacentral.com</a> of any unauthorised access.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">3. Subscription, billing, and renewal</h3>
          <p class="mb-3">Subscriptions are billed monthly in advance in Philippine Pesos at the rate displayed at checkout. Payment is processed by our payment partner, NextPay. By subscribing you authorise AVA (via NextPay) to charge the payment method on file on each renewal date until the subscription is cancelled. Promotional rates (including the 50% launch promo) apply only for the period stated at checkout and revert to the regular rate thereafter unless we agree otherwise in writing.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">4. Cancellation and refunds</h3>
          <p class="mb-3">You may cancel your subscription at any time from your account or by writing to <a href="mailto:hello@avaspacentral.com" class="text-emerald-brand underline">hello@avaspacentral.com</a>. Cancellation takes effect at the end of the current billing period and access continues until that date. Except where required by law, fees already paid are non-refundable. We do not pro-rate partial months.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">5. Plan limits and upgrades</h3>
          <p class="mb-3">Each plan tier carries explicit limits — including, but not limited to, the maximum number of branches and staff login accounts. Exceeding a limit requires an upgrade to a higher tier; AVA reserves the right to refuse the creation of additional branches or accounts beyond the limit of the active plan.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">6. Your data</h3>
          <p class="mb-3">All customer records, bookings, transactions, inventory, and other content you upload or generate through the Service (your <strong>"Business Data"</strong>) remain your property. You grant AVA a limited licence to host, process, and back up your Business Data solely to deliver the Service. We handle personal information in accordance with our <button type="button" data-open-legal="privacy" class="text-emerald-brand underline cursor-pointer">Privacy Policy</button> and the Philippine Data Privacy Act of 2012 (RA 10173).</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">7. Acceptable use</h3>
          <p class="mb-3">You agree not to (a) use the Service to send spam, malware, or unlawful content; (b) attempt to reverse-engineer, scrape, or disrupt the Service or its infrastructure; (c) resell or sublicense access without our written consent; or (d) use the Service in violation of any applicable Philippine law including data privacy, consumer protection, and labor regulations.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">8. Availability and changes</h3>
          <p class="mb-3">We target high availability but do not guarantee uninterrupted service. Scheduled maintenance, force majeure, and third-party outages (e.g. Supabase, NextPay) may cause temporary downtime. We may add, modify, or remove features at any time; material changes that disadvantage paying customers will be communicated at least fourteen (14) days in advance.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">9. Disclaimers and limitation of liability</h3>
          <p class="mb-3">The Service is provided "as is" and "as available" without warranties of any kind, express or implied. To the maximum extent permitted by Philippine law, AVA's aggregate liability for any claim arising out of or related to these Terms is limited to the fees the Customer paid to AVA in the twelve (12) months preceding the event giving rise to the claim. We are not liable for indirect, incidental, consequential, or lost-profits damages.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">10. Termination by AVA</h3>
          <p class="mb-3">We may suspend or terminate your account, with notice where practicable, if you (a) fail to pay fees when due, (b) violate these Terms, or (c) engage in conduct that puts the Service, other customers, or third parties at risk. Upon termination you may request an export of your Business Data within thirty (30) days, after which we may delete it.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">11. Governing law and disputes</h3>
          <p class="mb-3">These Terms are governed by the laws of the Republic of the Philippines. The parties shall first attempt to resolve any dispute in good faith. Failing that, the courts of the City of Manila shall have exclusive jurisdiction, without prejudice to either party's right to seek interim relief in any competent court.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">12. Changes to these Terms</h3>
          <p class="mb-3">We may update these Terms from time to time. Continued use of the Service after the effective date of an update constitutes acceptance. We will notify active subscribers of material changes by email at the address on file.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">13. Contact</h3>
          <p class="mb-2">Questions about these Terms? Reach us at <a href="mailto:hello@avaspacentral.com" class="text-emerald-brand underline">hello@avaspacentral.com</a>.</p>
        </article>

        <!-- PRIVACY POLICY -->
        <article id="legalContent-privacy" class="legal-prose text-[0.92rem] leading-relaxed text-ink hidden">
          <p class="text-[0.78rem] uppercase tracking-wider text-muted font-semibold mb-4">Last updated: May 2026</p>
          <p class="mb-4">This Privacy Policy explains how <strong>AVA Solutions PH</strong> (<strong>"AVA"</strong>, <strong>"we"</strong>) collects, uses, shares, and protects personal information when you sign up for or use AVA Spa Central. We comply with the <strong>Philippine Data Privacy Act of 2012 (RA 10173)</strong>, its Implementing Rules and Regulations, and applicable issuances of the National Privacy Commission.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">1. Who we are</h3>
          <p class="mb-3">AVA acts as the <strong>Personal Information Controller</strong> for account-holder data (the Owner who signs up) and as the <strong>Personal Information Processor</strong> for any personal data the Owner uploads about employees, customers, or other third parties through the Service.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">2. Information we collect</h3>
          <ul class="list-disc pl-5 space-y-1.5 mb-3">
            <li><strong>Account data:</strong> email, password (hashed), owner name, mobile number, business name and address.</li>
            <li><strong>Billing data:</strong> plan tier, amount paid, payment-method type, NextPay transaction reference. We do <em>not</em> store full card numbers — these stay with NextPay.</li>
            <li><strong>Business Data:</strong> records you create inside the platform (customers, employees, bookings, transactions, payroll, inventory).</li>
            <li><strong>Usage data:</strong> log-in events, IP address, device/browser metadata, error reports, and analytics events used to operate and improve the Service.</li>
          </ul>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">3. How and why we use it</h3>
          <p class="mb-2">We process personal information to:</p>
          <ul class="list-disc pl-5 space-y-1.5 mb-3">
            <li>Provide, maintain, and improve the Service (legal basis: performance of contract);</li>
            <li>Process subscription payments and prevent fraud (contract; legitimate interest);</li>
            <li>Send service-related notices, receipts, and security alerts (contract; legal obligation);</li>
            <li>Respond to support requests and customer enquiries (consent; legitimate interest);</li>
            <li>Comply with tax, accounting, and other Philippine legal obligations.</li>
          </ul>
          <p class="mb-3">We do <strong>not</strong> sell personal information and we do <strong>not</strong> use your Business Data to train AI models for third parties.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">4. Sharing with third parties</h3>
          <p class="mb-2">We share personal information only with the following categories of recipients, under written data-protection terms:</p>
          <ul class="list-disc pl-5 space-y-1.5 mb-3">
            <li><strong>Supabase</strong> — database hosting and authentication;</li>
            <li><strong>NextPay</strong> — subscription billing and payments;</li>
            <li><strong>Netlify</strong> — web hosting for the marketing site and serverless functions;</li>
            <li><strong>Email and notification providers</strong> — to deliver transactional messages;</li>
            <li><strong>Government authorities</strong> — when required by Philippine law, valid subpoena, or NPC directive.</li>
          </ul>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">5. Cross-border transfer</h3>
          <p class="mb-3">Some of our service providers (e.g. Supabase, Netlify) host data outside the Philippines. We rely on contractual safeguards and the providers' own data-protection commitments to ensure your information receives a comparable level of protection.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">6. Retention</h3>
          <p class="mb-3">We retain account and Business Data for as long as your subscription is active. After cancellation we retain your data for up to thirty (30) days to allow you to export it, then delete or anonymise it — except where a longer retention period is required by law (e.g. tax records, ten (10) years under the National Internal Revenue Code).</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">7. Your rights under the Data Privacy Act</h3>
          <p class="mb-2">As a data subject you have the right to:</p>
          <ul class="list-disc pl-5 space-y-1.5 mb-3">
            <li>Be informed about how your data is processed;</li>
            <li>Access a copy of your personal information;</li>
            <li>Have inaccurate data corrected;</li>
            <li>Erase or block data that is incomplete, outdated, false, or unlawfully obtained;</li>
            <li>Object to or withdraw consent for processing where consent is the legal basis;</li>
            <li>Receive your data in a structured, commonly-used format (portability);</li>
            <li>Lodge a complaint with the National Privacy Commission (<a href="https://www.privacy.gov.ph/" target="_blank" rel="noopener noreferrer" class="text-emerald-brand underline">privacy.gov.ph</a>).</li>
          </ul>
          <p class="mb-3">To exercise any of these rights, email <a href="mailto:hello@avaspacentral.com" class="text-emerald-brand underline">hello@avaspacentral.com</a>. We respond within fifteen (15) business days.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">8. Security</h3>
          <p class="mb-3">We implement organisational, physical, and technical safeguards including: encrypted-in-transit traffic (TLS), encryption at rest for database storage, role-based access control, multi-tenant isolation enforced by Row-Level Security, audit logging, scheduled backups, and least-privilege access for AVA personnel. No system is perfectly secure; we will notify affected users and the NPC of any personal-data breach in accordance with NPC Circular 16-03.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">9. Cookies and similar technologies</h3>
          <p class="mb-3">The marketing site and dashboard use strictly-necessary cookies (session, authentication, CSRF) and, where permitted, analytics cookies to understand usage patterns. You can disable non-essential cookies in your browser; doing so may impact functionality.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">10. Children</h3>
          <p class="mb-3">The Service is not directed at children under sixteen (16). We do not knowingly collect personal information from children. If you believe we have, please contact us so we can delete it.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">11. Changes</h3>
          <p class="mb-3">We may update this Policy from time to time. Material changes will be announced by email and posted on the marketing site at least fourteen (14) days before they take effect.</p>

          <h3 class="font-serif text-emerald-deep text-[1.05rem] font-semibold mt-6 mb-2">12. Contact and Data Protection Officer</h3>
          <p class="mb-2">For privacy questions, complaints, or to exercise your data-subject rights:</p>
          <p class="mb-1"><strong>AVA Solutions PH — Data Protection Officer</strong></p>
          <p class="mb-1">Email: <a href="mailto:hello@avaspacentral.com" class="text-emerald-brand underline">hello@avaspacentral.com</a></p>
          <p class="mb-3">You may also contact the National Privacy Commission at <a href="mailto:complaints@privacy.gov.ph" class="text-emerald-brand underline">complaints@privacy.gov.ph</a>.</p>
        </article>

      </div>

      <!-- Footer -->
      <div class="flex items-center justify-end gap-3 px-7 py-4 border-t border-border-soft bg-white">
        <button type="button" data-close-legal class="btn btn-primary px-6">I've read this</button>
      </div>
    </div>
  </div>

</Layout>

<script is:inline define:vars={{ plans, spaAppUrl }}>
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('plan');
  const plan = plans[slug] || plans.advance;

  document.getElementById('planName').textContent = plan.name;
  document.getElementById('planDesc').textContent = plan.desc;
  document.getElementById('planPromo').textContent = plan.promo;
  document.getElementById('planRegular').textContent = plan.regular;
  document.getElementById('subtotal').textContent = plan.promo;
  document.getElementById('total').textContent = plan.promo;

  // Plan-tier branch cap. Must match PLAN_BRANCH_CAPS in
  // netlify/functions/create-checkout-session.ts and PLAN_LIMITS in the
  // spa-app's AppContext — change all three together.
  const PLAN_BRANCH_CAPS = { starter: 1, advance: 3, enterprise: 50 };
  const branchCap = PLAN_BRANCH_CAPS[plan.slug] ?? 50;
  const branchesInput = document.getElementById('branchesInput');
  const branchesHint = document.getElementById('branchesHint');
  branchesInput.max = String(branchCap);
  if (parseInt(branchesInput.value, 10) > branchCap) branchesInput.value = String(branchCap);
  branchesHint.textContent =
    plan.slug === 'starter'    ? '1 branch only on Starter'
  : plan.slug === 'advance'    ? 'Up to 3 branches on Advance'
                               : 'Up to 50 branches on Enterprise';
  // Re-clamp on every keystroke so the user can't type a higher number.
  branchesInput.addEventListener('input', () => {
    const n = parseInt(branchesInput.value, 10);
    if (Number.isFinite(n) && n > branchCap) branchesInput.value = String(branchCap);
  });

  const featsList = document.getElementById('planFeats');
  featsList.innerHTML = plan.feats.map(f => `
    <li class="flex items-start gap-2.5 text-[0.88rem] !text-white/85">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-4 h-4 text-gold-soft flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
      <span>${f}</span>
    </li>
  `).join('');

  // Escape user/server-supplied strings before interpolating into the
  // error block — error detail from the server can contain quotes /
  // angle brackets when surfacing SQL messages.
  const escapeHtml = (s) => String(s ?? '')
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');

  // Form submit — POSTs directly to /api/create-checkout-session so the
  // password never lands in sessionStorage. The server stores it briefly
  // in checkout_sessions (service-role only, ~30 min TTL) and returns a
  // token the browser uses for the remaining steps.
  const form = document.getElementById('checkoutForm');
  const passwordError = document.getElementById('passwordError');
  const submitBtn = form.querySelector('button[type="submit"]');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));

    if (data.password !== data.passwordConfirm) {
      passwordError.classList.remove('hidden');
      return;
    }
    passwordError.classList.add('hidden');

    const planPriceNumeric = parseInt(plan.promo.replace(/[^0-9]/g, ''), 10) || 0;

    const payload = {
      email: String(data.email || '').trim().toLowerCase(),
      password: String(data.password || ''),
      businessName: String(data.businessName || '').trim(),
      businessAddress: String(data.address || '').trim(),
      businessPhone: String(data.phone || '').trim(),
      branchesCount: Math.min(branchCap, Math.max(1, parseInt(String(data.branches || '1'), 10) || 1)),
      planTier: plan.slug,
      amountPhp: planPriceNumeric,
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Setting up…';

    try {
      const res = await fetch('/api/create-checkout-session', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      // Try JSON first; if the function 502'd Netlify returns plaintext, so
      // fall back to text() so we still surface SOMETHING actionable to the
      // user instead of "Could not start checkout".
      let result = {};
      let rawText = '';
      try {
        result = await res.clone().json();
      } catch {
        try { rawText = await res.text(); } catch { rawText = '<unreadable>'; }
      }

      if (!res.ok) {
        // Always log the full server response to console so the user can
        // copy/paste it back to support when reporting an issue.
        console.error('[checkout] server error', { status: res.status, result, rawText });

        if (result?.error === 'email_already_registered') {
          const loginHref = (spaAppUrl || '').replace(/\/$/, '') + '/login';
          passwordError.innerHTML = `May AVA account na sa email na ito. <a href="${loginHref}" class="underline">Mag-login na lang →</a>`;
        } else {
          // Build a verbose, copy-pasteable error block so a customer (or
          // anyone on support) can see exactly which stage broke without
          // opening DevTools.
          const parts = [];
          parts.push(`<strong>Sign-up error</strong> (HTTP ${res.status})`);
          if (result?.error)  parts.push(`Code: <code>${escapeHtml(result.error)}</code>`);
          if (result?.stage)  parts.push(`Stage: <code>${escapeHtml(result.stage)}</code>`);
          if (result?.detail) parts.push(`Detail: ${escapeHtml(result.detail)}`);
          if (result?.hint)   parts.push(`<em>Hint:</em> ${escapeHtml(result.hint)}`);
          if (Array.isArray(result?.missing) && result.missing.length) {
            parts.push(`Missing: <code>${result.missing.map(escapeHtml).join(', ')}</code>`);
          }
          if (!result?.detail && rawText) {
            parts.push(`Body: <code>${escapeHtml(rawText.slice(0, 200))}</code>`);
          }
          if (parts.length === 1) parts.push('Could not start checkout. Open DevTools → Console for the full response and check Netlify Function logs.');
          passwordError.innerHTML = parts.join('<br>');
        }
        passwordError.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Continue to Payment →';
        return;
      }

      // Only non-secret state is stashed for the UI on later pages. The
      // server holds the password; this stash exists so a refresh on
      // /checkout/payment doesn't lose plan/business labels.
      sessionStorage.setItem('ava_checkout', JSON.stringify({
        token: result.token,
        plan: plan.slug,
        planName: plan.name,
        planPrice: plan.promo,
        businessName: payload.businessName,
        email: payload.email,
        devMode: !!result.devMode,
      }));

      window.location.href = result.paymentUrl
        || `/checkout/payment?session=${encodeURIComponent(result.token)}`;
    } catch (err) {
      console.error('[checkout] network error', err);
      passwordError.innerHTML = `<strong>Network error</strong><br>${escapeHtml(err?.message || err)}<br><em>Hint:</em> check your connection, then refresh and try again. If it keeps failing, the function is unreachable — check Netlify Functions logs.`;
      passwordError.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Continue to Payment →';
    }
  });

  // ----- Legal modal open/close ------------------------------------------
  // Two-panel modal that shows either the Terms or the Privacy article
  // depending on which link was clicked. Body scroll is locked while the
  // modal is open so the long legal text scrolls inside the dialog instead
  // of doubling the scroll surface with the page underneath.
  const legalModal = document.getElementById('legalModal');
  const legalTitle = document.getElementById('legalModalTitle');
  const legalEyebrow = document.getElementById('legalModalEyebrow');
  const legalPanels = {
    terms:   document.getElementById('legalContent-terms'),
    privacy: document.getElementById('legalContent-privacy'),
  };
  const LEGAL_META = {
    terms:   { title: 'Terms of Service', eyebrow: 'Legal · Subscriber Agreement' },
    privacy: { title: 'Privacy Policy',   eyebrow: 'Legal · Data Privacy Act 2012' },
  };

  function openLegal(kind) {
    if (!legalPanels[kind]) return;
    Object.values(legalPanels).forEach((el) => el && el.classList.add('hidden'));
    legalPanels[kind].classList.remove('hidden');
    legalTitle.textContent = LEGAL_META[kind].title;
    legalEyebrow.textContent = LEGAL_META[kind].eyebrow;
    legalModal.classList.remove('hidden');
    legalModal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    // Scroll the dialog body back to the top each time it opens.
    const body = legalModal.querySelector('.overflow-y-auto');
    if (body) body.scrollTop = 0;
  }

  function closeLegal() {
    legalModal.classList.add('hidden');
    legalModal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  // Delegated open: matches the inline checkout consent line AND the
  // "Privacy Policy" cross-link embedded inside the Terms article.
  document.addEventListener('click', (e) => {
    const opener = e.target instanceof Element && e.target.closest('[data-open-legal]');
    if (opener) {
      e.preventDefault();
      openLegal(opener.getAttribute('data-open-legal'));
    }
    const closer = e.target instanceof Element && e.target.closest('[data-close-legal]');
    if (closer || e.target === document.getElementById('legalModalClose')) {
      closeLegal();
    }
  });

  // Close on backdrop click (target IS the modal overlay itself, not a child)
  legalModal.addEventListener('click', (e) => {
    if (e.target === legalModal) closeLegal();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !legalModal.classList.contains('hidden')) closeLegal();
  });
</script>
