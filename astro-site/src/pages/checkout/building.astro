---
import Layout from '../../layouts/Layout.astro';

// Where the spa PWA lives. Override on Netlify by setting
// PUBLIC_SPA_APP_URL in Site settings → Build & deploy → Environment.
// Falls back to the local Vite dev server for local development.
const spaAppUrl = import.meta.env.PUBLIC_SPA_APP_URL || 'http://localhost:3000';
---

<Layout title="Building Your Spa — AVA Spa Central" description="We're setting up your AVA Spa Central account. This will only take a moment.">

  <section class="min-h-[90vh] flex items-center justify-center py-[60px]" style="background: radial-gradient(circle at 15% 30%, rgba(0,92,69,.07) 0%, transparent 42%), radial-gradient(circle at 85% 70%, rgba(201,154,58,.09) 0%, transparent 45%), var(--color-ivory);">
    <div class="container-spa">
      <div class="max-w-[640px] mx-auto">

        <!-- Top status -->
        <div class="text-center mb-10">
          <div class="relative inline-flex items-center justify-center w-24 h-24 mb-7">
            <!-- Pulsing rings -->
            <span class="absolute inset-0 rounded-full bg-emerald-brand/15 animate-ping"></span>
            <span class="absolute inset-2 rounded-full bg-emerald-brand/25 animate-pulse"></span>
            <span class="relative w-16 h-16 rounded-full bg-emerald-brand shadow-lg-spa flex items-center justify-center">
              <svg viewBox="0 0 32 32" fill="currentColor" class="w-9 h-9 text-gold-soft">
                <path d="M16 4 C 18 8, 22 11, 16 16 C 10 11, 14 8, 16 4 Z M16 16 C 20 18, 24 22, 18 26 C 14 24, 14 20, 16 16 Z M16 16 C 12 18, 8 22, 14 26 C 18 24, 18 20, 16 16 Z M6 14 C 8 12, 12 13, 14 16 C 10 17, 7 16, 6 14 Z M26 14 C 24 12, 20 13, 18 16 C 22 17, 25 16, 26 14 Z"/>
              </svg>
            </span>
          </div>
          <span class="eyebrow inline-block mb-3">Setting Up Your Account</span>
          <h1 class="mb-3 text-[clamp(1.8rem,3.5vw,2.4rem)]">Building your <span class="italic text-emerald-brand font-medium">spa software…</span></h1>
          <p id="statusText" class="text-base text-muted leading-relaxed">Sandali lang — naghahanda kami ng dashboard mo.</p>
        </div>

        <!-- Progress bar -->
        <div class="bg-white border border-border-soft rounded-2xl p-8 shadow-md-spa mb-6">
          <div class="flex items-center justify-between mb-3">
            <span class="text-[0.78rem] uppercase tracking-wider text-muted font-semibold">Progress</span>
            <span id="progressLabel" class="text-[0.86rem] text-emerald-deep font-semibold tabular-nums">0%</span>
          </div>
          <div class="h-2 bg-border-soft rounded-full overflow-hidden mb-7">
            <div id="progressBar" class="h-full bg-gradient-to-r from-emerald-brand to-emerald-hover rounded-full transition-all duration-500 ease-out" style="width: 0%;"></div>
          </div>

          <!-- Steps -->
          <ul id="stepList" class="list-none flex flex-col gap-3 m-0 p-0">
            <li data-step="0" class="flex items-center gap-3.5 step-item">
              <span class="step-icon flex-shrink-0 w-7 h-7 rounded-full border border-border-soft bg-ivory flex items-center justify-center">
                <span class="step-num text-[0.74rem] text-muted font-bold">1</span>
                <svg class="step-check hidden w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="step-spin hidden w-3.5 h-3.5 border-2 border-emerald-brand border-t-transparent rounded-full animate-spin"></span>
              </span>
              <span class="step-label text-[0.92rem] text-muted font-medium flex-1">Payment confirmed</span>
            </li>
            <li data-step="1" class="flex items-center gap-3.5 step-item">
              <span class="step-icon flex-shrink-0 w-7 h-7 rounded-full border border-border-soft bg-ivory flex items-center justify-center">
                <span class="step-num text-[0.74rem] text-muted font-bold">2</span>
                <svg class="step-check hidden w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="step-spin hidden w-3.5 h-3.5 border-2 border-emerald-brand border-t-transparent rounded-full animate-spin"></span>
              </span>
              <span class="step-label text-[0.92rem] text-muted font-medium flex-1">Creating your AVA account</span>
            </li>
            <li data-step="2" class="flex items-center gap-3.5 step-item">
              <span class="step-icon flex-shrink-0 w-7 h-7 rounded-full border border-border-soft bg-ivory flex items-center justify-center">
                <span class="step-num text-[0.74rem] text-muted font-bold">3</span>
                <svg class="step-check hidden w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="step-spin hidden w-3.5 h-3.5 border-2 border-emerald-brand border-t-transparent rounded-full animate-spin"></span>
              </span>
              <span class="step-label text-[0.92rem] text-muted font-medium flex-1">Setting up your spa business profile</span>
            </li>
            <li data-step="3" class="flex items-center gap-3.5 step-item">
              <span class="step-icon flex-shrink-0 w-7 h-7 rounded-full border border-border-soft bg-ivory flex items-center justify-center">
                <span class="step-num text-[0.74rem] text-muted font-bold">4</span>
                <svg class="step-check hidden w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="step-spin hidden w-3.5 h-3.5 border-2 border-emerald-brand border-t-transparent rounded-full animate-spin"></span>
              </span>
              <span class="step-label text-[0.92rem] text-muted font-medium flex-1">Configuring branches and team access</span>
            </li>
            <li data-step="4" class="flex items-center gap-3.5 step-item">
              <span class="step-icon flex-shrink-0 w-7 h-7 rounded-full border border-border-soft bg-ivory flex items-center justify-center">
                <span class="step-num text-[0.74rem] text-muted font-bold">5</span>
                <svg class="step-check hidden w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="step-spin hidden w-3.5 h-3.5 border-2 border-emerald-brand border-t-transparent rounded-full animate-spin"></span>
              </span>
              <span class="step-label text-[0.92rem] text-muted font-medium flex-1">Building your dashboard</span>
            </li>
            <li data-step="5" class="flex items-center gap-3.5 step-item">
              <span class="step-icon flex-shrink-0 w-7 h-7 rounded-full border border-border-soft bg-ivory flex items-center justify-center">
                <span class="step-num text-[0.74rem] text-muted font-bold">6</span>
                <svg class="step-check hidden w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="step-spin hidden w-3.5 h-3.5 border-2 border-emerald-brand border-t-transparent rounded-full animate-spin"></span>
              </span>
              <span class="step-label text-[0.92rem] text-muted font-medium flex-1">Preparing your installable app</span>
            </li>
          </ul>
        </div>

        <!-- Fallback / ready state -->
        <div id="readyPanel" class="hidden bg-emerald-deep text-white rounded-2xl p-7 shadow-lg-spa text-center">
          <div class="inline-flex items-center justify-center w-14 h-14 bg-gold-brand rounded-full mb-4">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="w-7 h-7 text-emerald-deep"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3 class="!text-white text-[1.4rem] font-serif font-semibold mb-2">Ready ka na!</h3>
          <p class="!text-white/75 text-[0.92rem] mb-6 leading-relaxed">Bumukas dapat ang install page sa bagong tab. Tap "Install" doon para i-add ang AVA app sa home screen mo.</p>
          <button id="openDashboardBtn" type="button" class="btn btn-gold px-8">Install AVA App →</button>
          <p class="text-[0.78rem] !text-white/55 mt-5">Hindi bumubukas? Make sure tumatakbo ang spa app sa <code class="font-mono !text-gold-soft">localhost:3000</code></p>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script is:inline>
  // Poll /api/check-provisioning-status until the server reports the
  // tenant has been fully created (auth user + business + branches +
  // subscription). The on-screen steps tick forward as the status
  // transitions: pending -> paid -> provisioned. On 'failed' we surface
  // the error inline instead of redirecting blindly.

  // Token resolution: URL query is authoritative (refresh-safe) and the
  // sessionStorage stash is a fallback for older flows that don't pass
  // it on the navigation. No token at all → back to step 1.
  const tokenFromUrl = new URLSearchParams(window.location.search).get('session');
  const raw = sessionStorage.getItem('ava_checkout');
  const stash = raw ? JSON.parse(raw) : null;
  const token = tokenFromUrl || stash?.token;

  if (!token) {
    window.location.href = '/checkout';
  }

  const statusText = document.getElementById('statusText');
  const progressBar = document.getElementById('progressBar');
  const progressLabel = document.getElementById('progressLabel');
  const stepItems = document.querySelectorAll('.step-item');
  const readyPanel = document.getElementById('readyPanel');
  const openDashboardBtn = document.getElementById('openDashboardBtn');

  // Each step maps to a phase of the server's lifecycle. We bring the
  // step-by-step animation forward as status transitions arrive so the
  // user gets a smooth fill rather than a sudden 0 -> 100 jump.
  const PHASES = [
    { idx: 0, label: 'Payment confirmed',                       statuses: ['paid', 'provisioned'] },
    { idx: 1, label: 'Creating your AVA account',               statuses: ['provisioned'] },
    { idx: 2, label: 'Setting up your spa business profile',    statuses: ['provisioned'] },
    { idx: 3, label: 'Configuring branches and team access',    statuses: ['provisioned'] },
    { idx: 4, label: 'Building your dashboard',                 statuses: ['provisioned'] },
    { idx: 5, label: 'Preparing your installable app',          statuses: ['provisioned'] },
  ];

  function setStepState(idx, state) {
    const item = stepItems[idx];
    if (!item) return;
    const icon = item.querySelector('.step-icon');
    const num = item.querySelector('.step-num');
    const check = item.querySelector('.step-check');
    const spin = item.querySelector('.step-spin');
    const label = item.querySelector('.step-label');

    icon.classList.remove('bg-emerald-brand', 'border-emerald-brand', 'bg-ivory', 'border-border-soft');

    if (state === 'active') {
      icon.classList.add('border-emerald-brand', 'bg-ivory');
      num.classList.add('hidden');
      check.classList.add('hidden');
      spin.classList.remove('hidden');
      label.classList.remove('text-muted');
      label.classList.add('text-ink');
    } else if (state === 'done') {
      icon.classList.add('bg-emerald-brand', 'border-emerald-brand');
      num.classList.add('hidden');
      spin.classList.add('hidden');
      check.classList.remove('hidden');
      label.classList.remove('text-muted');
      label.classList.add('text-emerald-deep');
    }
  }

  function setProgress(pct) {
    progressBar.style.width = pct + '%';
    progressLabel.textContent = pct + '%';
  }

  function markPhasesUpTo(idx) {
    for (let i = 0; i <= idx; i++) setStepState(i, 'done');
  }

  async function poll() {
    const res = await fetch(`/api/check-provisioning-status?token=${encodeURIComponent(token)}`);
    if (!res.ok) throw new Error('status_lookup_failed');
    return await res.json();
  }

  function failWith(message) {
    statusText.textContent = message;
    statusText.classList.add('text-red-600');
  }

  let activeStep = 0;
  let stopped = false;

  // Tick the next "in-flight" step's spinner so users see motion while the
  // server actually does the work. The forward-progress is gated by the
  // server's status, but we don't want to look frozen between transitions.
  setStepState(0, 'active');
  setProgress(8);

  const tickInterval = setInterval(() => {
    if (stopped) return;
    if (activeStep < 5) {
      setStepState(activeStep, 'active');
    }
  }, 700);

  async function run() {
    const start = Date.now();
    const TIMEOUT_MS = 90_000;

    while (!stopped) {
      let data;
      try {
        data = await poll();
      } catch (err) {
        if (Date.now() - start > TIMEOUT_MS) {
          failWith('Provisioning is taking longer than expected. Please refresh in a moment.');
          stopped = true;
          clearInterval(tickInterval);
          return;
        }
        await new Promise((r) => setTimeout(r, 1500));
        continue;
      }

      if (data.status === 'failed' || data.status === 'expired') {
        clearInterval(tickInterval);
        stopped = true;
        failWith(
          data.failureReason
            ? `Couldn't finish your account: ${data.failureReason}`
            : 'Couldn\'t finish your account. Please contact support@avaspacentral.com.',
        );
        return;
      }

      if (data.status === 'paid' && activeStep < 1) {
        setStepState(0, 'done');
        setStepState(1, 'active');
        activeStep = 1;
        setProgress(30);
      }

      if (data.status === 'provisioned') {
        clearInterval(tickInterval);
        stopped = true;
        markPhasesUpTo(5);
        setProgress(100);
        statusText.textContent = 'Tapos na! Redirecting to your welcome page…';

        // Stash the resolved URLs so /checkout/success can render them
        // without needing to re-poll.
        sessionStorage.setItem('ava_checkout_result', JSON.stringify({
          bookingUrl: data.bookingUrl,
          bookingSlug: data.bookingSlug,
          installUrl: data.installUrl,
          loginUrl: data.loginUrl,
          email: data.email,
          businessName: data.businessName,
          planTier: data.planTier,
          amountPhp: data.amountPhp,
          paymentMethod: data.paymentMethod,
          nextBillingAt: data.nextBillingAt,
        }));

        readyPanel.classList.remove('hidden');
        openDashboardBtn.addEventListener('click', () => {
          if (data.installUrl) window.open(data.installUrl, '_blank', 'noopener,noreferrer');
        });

        setTimeout(() => {
          window.location.href = `/checkout/success?session=${encodeURIComponent(token)}`;
        }, 1500);
        return;
      }

      // Still pending or paid-but-not-yet-provisioned. Slow poll.
      if (Date.now() - start > TIMEOUT_MS) {
        clearInterval(tickInterval);
        stopped = true;
        failWith('Provisioning is taking longer than expected. Please refresh in a moment.');
        return;
      }
      await new Promise((r) => setTimeout(r, 1500));
    }
  }

  run();
</script>
