# Marketing site environment variables.
# Copy to .env for local development. Set the production values in
# Netlify Site settings → Build & deploy → Environment.

# Where the spa PWA (the customer-facing app) is hosted. The checkout
# success / building pages link the "Install AVA App" CTA to
# ${PUBLIC_SPA_APP_URL}/install, and the provisioning functions use the
# same value to construct the per-tenant booking URL.
#
# Local dev (when running `cd ../spa-app && npm run dev`):
PUBLIC_SPA_APP_URL=http://localhost:3000
#
# Example production value:
# PUBLIC_SPA_APP_URL=https://spacentralapp.avasolutions.ph

# --- Server-only (Netlify Functions). NEVER expose to the browser. ---

# Supabase project URL. The REST endpoint is public-by-design (visible in
# any browser request from the spa-app), but Netlify's secret scanner
# flags it if its value appears in the build output — so don't commit the
# real value here; set it in Netlify Site settings → Environment.
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase service-role key. Used by the checkout / provisioning functions
# to create auth users and insert tenant rows while bypassing RLS. Treat
# as a database password.
SUPABASE_SERVICE_ROLE_KEY=

# NextPay credentials. Leave NEXTPAY_CLIENT_SECRET unset to run the
# checkout flow in dev mode (the marketing site renders a "Pay (simulate)"
# button that calls the webhook directly with no real charge). Set both
# values + the webhook secret to flip into real billing.
#
# To activate real NextPay (one-time):
#   1. Get sandbox creds from https://nextpayph.stoplight.io (or your
#      NextPay merchant dashboard). They issue client_key + client_secret.
#   2. Set NEXTPAY_CLIENT_KEY + NEXTPAY_CLIENT_SECRET on Netlify
#      (Site settings → Build & deploy → Environment).
#   3. Set NEXTPAY_WEBHOOK_SECRET to the same value you give NextPay's
#      dashboard for the webhook target. The endpoint NextPay should call
#      is https://<your-marketing-site>.netlify.app/api/nextpay-webhook.
#   4. NEXTPAY_ENV=sandbox until you've test-paid end-to-end; flip to
#      "production" only after you've confirmed sandbox flow works.
#
# Once NEXTPAY_CLIENT_SECRET is set, the marketing-site /checkout/payment
# page automatically:
#   - calls /api/create-payment-intent on submit
#   - renders the QRPh code returned by NextPay
#   - polls the session status and forwards to /checkout/building when paid
#
# Today only GCash, Maya, and other QRPh-compatible wallets work. Card,
# online bank transfer, and OTC need NextPay's hosted-checkout endpoint
# (not yet wired). Customers who pick those will get a clear "not yet
# supported" message instead of a silent failure.
NEXTPAY_CLIENT_KEY=
NEXTPAY_CLIENT_SECRET=
NEXTPAY_WEBHOOK_SECRET=
NEXTPAY_ENV=sandbox

# Optional soft gate for the dev-mode webhook. If set, the marketing site
# must include the same value in its mock-pay POST. Acts as a "don't fire
# this by accident" check during testing; not a security boundary.
CHECKOUT_DEV_KEY=
