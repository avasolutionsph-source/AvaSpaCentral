<footer class="bg-emerald-deep text-white/80 pt-16 pb-7 relative">
  <div class="container-spa">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-[1.5fr_1fr_1fr_1fr] gap-12 mb-12">
      <div>
        <a href="/" class="flex items-center gap-2.5 no-underline text-white font-serif mb-4">
          <svg viewBox="0 0 32 32" fill="currentColor" class="w-[34px] h-[34px] text-gold-brand">
            <path d="M16 4 C 18 8, 22 11, 16 16 C 10 11, 14 8, 16 4 Z M16 16 C 20 18, 24 22, 18 26 C 14 24, 14 20, 16 16 Z M16 16 C 12 18, 8 22, 14 26 C 18 24, 18 20, 16 16 Z"/>
          </svg>
          <span class="flex flex-col leading-none">
            <strong class="text-[1.25rem] font-semibold text-white">AVA Spa Central</strong>
            <small class="text-[0.6rem] tracking-[0.32em] text-white/55 font-sans font-semibold mt-[3px]">SOFTWARE</small>
          </span>
        </a>
        <p class="text-white/60 text-[0.88rem] max-w-[320px] leading-relaxed">The all-in-one spa management software built to help you manage smarter, operate efficiently and grow your business.</p>
      </div>

      <div>
        <h5 class="text-gold-soft text-[0.72rem] uppercase tracking-[0.14em] font-bold mb-5 font-sans">Quick Links</h5>
        <ul class="list-none flex flex-col gap-2.5 m-0 p-0">
          <li><a href="/" class="text-white/70 no-underline text-[0.88rem] hover:text-gold-soft transition-colors">Home</a></li>
          <li><a href="/features" class="text-white/70 no-underline text-[0.88rem] hover:text-gold-soft transition-colors">Features</a></li>
          <li><a href="/pricing" class="text-white/70 no-underline text-[0.88rem] hover:text-gold-soft transition-colors">Pricing</a></li>
        </ul>
      </div>

      <div>
        <h5 class="text-gold-soft text-[0.72rem] uppercase tracking-[0.14em] font-bold mb-5 font-sans">Features</h5>
        <ul class="list-none flex flex-col gap-2.5 m-0 p-0">
          <li class="text-white/70 text-[0.88rem]">Booking</li>
          <li class="text-white/70 text-[0.88rem]">POS &amp; Sales</li>
          <li class="text-white/70 text-[0.88rem]">Employee Monitoring</li>
          <li class="text-white/70 text-[0.88rem]">Room Management</li>
          <li class="text-white/70 text-[0.88rem]">Inventory</li>
          <li class="text-white/70 text-[0.88rem]">Reports &amp; Analytics</li>
        </ul>
      </div>

      <div>
        <h5 class="text-gold-soft text-[0.72rem] uppercase tracking-[0.14em] font-bold mb-5 font-sans">Contact</h5>
        <ul class="list-none flex flex-col gap-2.5 m-0 p-0">
          <li class="text-white/70 text-[0.88rem]">+63 912 345 6789</li>
          <li class="text-white/70 text-[0.88rem]">hello@avaspacentral.com</li>
          <li class="text-white/70 text-[0.88rem]">123 Wellness St., Makati City</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-6 flex justify-between items-center flex-wrap gap-3 text-[0.8rem] text-white/45">
      <div>© 2026 AVA Spa Central. All rights reserved.</div>
      <div>Made with care for spa owners.</div>
    </div>
  </div>
</footer>
