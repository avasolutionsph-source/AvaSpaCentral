# Supabase Configuration (Required for production)
# Get these from your Supabase project: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: AI Features (if using OpenAI-powered chatbot)
# VITE_OPENAI_API_KEY=your-openai-key-here

# Optional: Error Monitoring (Sentry)
# Get your DSN from https://sentry.io - create a React project
# VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Web Push (background notifications when app is closed/locked)
# Generate locally: node scripts/generate-vapid-keys.mjs
# Public key is safe to commit; the matching PRIVATE key goes into the
# Supabase notify-push function as VAPID_PRIVATE_KEY (never commit it).
# VITE_VAPID_PUBLIC_KEY=
